# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# ID администратора бота (ваш Telegram ID)
ADMIN_ID=123456789

# Настройки базы данных PostgreSQL (опционально)
# Если не указаны, будет использоваться SQLite
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=sizerandom_bot
# DB_USER=postgres
# DB_PASSWORD=your_password

# Использовать SQLite (True) или PostgreSQL (False)
USE_SQLITE=True
